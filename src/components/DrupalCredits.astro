---
interface ProjectCount {
  label: string;
  count: number;
}
interface Props {
  totalCount: number;
  projects: ProjectCount[];
  creditsUrl?: string;
}
const {
  totalCount,
  projects,
  creditsUrl = 'https://www.drupal.org/user/3557964/contribution-records',
} = Astro.props;
---

<div class="credits-card">
  <p class="credits-eyebrow">Open Source Contributions</p>

  <div class="credits-total-row">
    <span class="credits-count">{totalCount}</span>
    <span class="credits-count-label">credits on Drupal.org</span>
  </div>

  {projects.length > 0 && (
    <div class="credits-pills">
      {projects.map((p) => (
        <span class="credits-pill">
          {p.label}
          <span class="credits-pill-count">{p.count}</span>
        </span>
      ))}
    </div>
  )}

  <a href={creditsUrl} target="_blank" rel="noopener noreferrer" class="credits-link">
    View all on Drupal.org
    <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none"
      stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
    </svg>
  </a>
</div>

<style>
  .credits-card {
    margin-top: 1.75rem;
    padding: 1.25rem 1.5rem;
    border: 1px solid rgb(var(--gray-light));
    border-radius: 12px;
    background: rgba(var(--accent-rgb), 0.03);
    border-left: 3px solid rgba(var(--accent-rgb), 0.35);
  }
  .credits-eyebrow {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgb(var(--gray));
    margin: 0 0 0.75rem;
  }
  .credits-total-row {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.875rem;
  }
  .credits-count {
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 1;
    color: var(--accent);
  }
  .credits-count-label {
    font-size: 0.875rem;
    color: rgb(var(--gray-dark));
  }
  .credits-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .credits-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.78rem;
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
    border: 1px solid rgb(var(--gray-light));
    background: rgb(var(--gray-light));
    color: rgb(var(--gray-dark));
  }
  .credits-pill-count {
    font-weight: 700;
    color: var(--accent);
  }
  .credits-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .credits-link:hover {
    opacity: 0.75;
    text-decoration: none;
  }
</style>
