---
const socialLinks = [
  { href: 'https://drupal.org/u/abhisekmazumdar',    label: 'Drupal',    icon: 'fa-brands fa-drupal' },
  { href: 'https://github.com/abhisekmazumdar',      label: 'GitHub',    icon: 'fa-brands fa-github' },
  { href: 'https://linkedin.com/in/abhisekmazumdar', label: 'LinkedIn',  icon: 'fa-brands fa-linkedin-in' },
  { href: 'https://www.instagram.com/abhisek.travel',label: 'Instagram', icon: 'fa-brands fa-instagram' },
  { href: 'https://www.reddit.com/user/abhisekmazumdar', label: 'Reddit', icon: 'fa-brands fa-reddit-alien' },
];

const year = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <div class="social-row">
      {socialLinks.map(({ href, label, icon }) => (
        <a href={href} target="_blank" rel="noopener noreferrer" aria-label={label} title={label} class="social-btn">
          <i class={`${icon}`} aria-hidden="true"></i>
        </a>
      ))}
    </div>

    <p class="footer-copy">&copy; {year} Abhisek Mazumdar &middot; abhisek.xyz</p>

    <p class="footer-ai">
      Actively developed &amp; maintained with
      <a href="https://claude.ai/code" target="_blank" rel="noopener noreferrer">Claude Code</a>
    </p>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid rgb(var(--gray-light));
    padding: 2rem 1.25rem;
    background: transparent;
  }
  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    max-width: 960px;
    margin: 0 auto;
  }
  .social-row {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-bottom: 0.25rem;
  }
  .social-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 8px;
    text-decoration: none;
    color: rgb(var(--gray));
    font-size: 1.1rem;
    transition: color 0.15s, background 0.15s;
  }
  .social-btn:hover {
    color: var(--accent);
    background: rgba(var(--accent-rgb), 0.08);
  }
  .footer-copy {
    font-size: 0.78rem;
    color: rgb(var(--gray));
    margin: 0;
    letter-spacing: 0.02em;
  }
  .footer-ai {
    font-size: 0.72rem;
    color: rgb(var(--gray));
    margin: 0;
    opacity: 0.7;
  }
  .footer-ai a {
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
  }
  .footer-ai a:hover {
    text-decoration: underline;
  }
</style>
