---
const socialLinks = [
  { href: 'https://drupal.org/u/abhisekmazumdar', label: 'Drupal', icon: 'fa-brands fa-drupal' },
  { href: 'https://github.com/abhisekmazumdar', label: 'GitHub', icon: 'fa-brands fa-github' },
  { href: 'https://linkedin.com/in/abhisekmazumdar', label: 'LinkedIn', icon: 'fa-brands fa-linkedin-in' },
  { href: 'https://www.instagram.com/abhisek.travel', label: 'Instagram', icon: 'fa-brands fa-instagram' },
  { href: 'https://www.reddit.com/user/abhisekmazumdar', label: 'Reddit', icon: 'fa-brands fa-reddit-alien' },
];
---

<footer class="mt-auto py-8 px-4 text-center" style="background: linear-gradient(var(--gray-gradient)) no-repeat; color: rgb(var(--gray));">
  <div class="mx-auto max-w-screen-xl">
    <div class="flex justify-center gap-3 mb-4">
      {socialLinks.map(({ href, label, icon }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={label}
          title={label}
          class="inline-flex items-center justify-center w-10 h-10 rounded-full no-underline transition-all hover:scale-110"
          style="color: rgb(var(--gray));"
          onmouseover="this.style.color='rgb(var(--gray-dark))'"
          onmouseout="this.style.color='rgb(var(--gray))'"
        >
          <i class={`${icon} text-2xl`} aria-hidden="true"></i>
        </a>
      ))}
    </div>
    <p class="text-sm m-0" style="color: rgb(var(--gray));">abhisek.xyz</p>
  </div>
</footer>
