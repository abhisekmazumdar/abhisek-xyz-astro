---
const socialLinks = [
  { href: 'https://drupal.org/u/abhisekmazumdar',    label: 'Drupal',    icon: 'fa-brands fa-drupal' },
  { href: 'https://github.com/abhisekmazumdar',      label: 'GitHub',    icon: 'fa-brands fa-github' },
  { href: 'https://linkedin.com/in/abhisekmazumdar', label: 'LinkedIn',  icon: 'fa-brands fa-linkedin-in' },
  { href: 'https://www.instagram.com/abhisek.travel',label: 'Instagram', icon: 'fa-brands fa-instagram' },
  { href: 'https://www.reddit.com/user/abhisekmazumdar', label: 'Reddit', icon: 'fa-brands fa-reddit-alien' },
];
---

<footer>
  <div class="footer-inner">
    <div class="social-row">
      {socialLinks.map(({ href, label, icon }) => (
        <a href={href} target="_blank" rel="noopener noreferrer" aria-label={label} title={label} class="social-btn">
          <i class={`${icon}`} aria-hidden="true"></i>
        </a>
      ))}
    </div>
    <p class="footer-label">abhisek.xyz</p>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid rgb(var(--gray-light));
    padding: 2rem 1.25rem;
    background: transparent;
  }
  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    max-width: 960px;
    margin: 0 auto;
  }
  .social-row {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  .social-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 8px;
    text-decoration: none;
    color: rgb(var(--gray));
    font-size: 1.1rem;
    transition: color 0.15s, background 0.15s;
  }
  .social-btn:hover {
    color: var(--accent);
    background: rgba(var(--accent-rgb), 0.08);
  }
  .footer-label {
    font-size: 0.8rem;
    color: rgb(var(--gray));
    margin: 0;
    letter-spacing: 0.02em;
  }
</style>
