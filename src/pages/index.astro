---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DrupalCredits from '../components/DrupalCredits.astro';
import {
  SITE_TITLE,
  SITE_DESCRIPTION,
  DRUPAL_ORG_UID,
  DRUPAL_CREDITS_OVERRIDE,
  DRUPAL_CREDITS_PROJECTS,
  DRUPAL_ORG_CREDITS_URL,
  DRUPAL_ORG_CREDITS_OVERRIDE,
} from '../consts';
import { getDrupalCredits } from '../lib/drupal-credits';
import { getDrupalOrgCredits } from '../lib/drupal-org-credits';
import ProfileImage from '../assets/abhisek.jpg';
import About from '../content/about.md';
import { Image } from 'astro:assets';

let { total, projects } = await getDrupalCredits({
  uid: DRUPAL_ORG_UID,
  projects: DRUPAL_CREDITS_PROJECTS,
});
const override = DRUPAL_CREDITS_OVERRIDE;
if (override) {
  if (override.total !== undefined) total = override.total;
  projects = projects.map((p) => ({
    ...p,
    count: override[p.machineName] ?? p.count,
  }));
}
const orgCredits = DRUPAL_ORG_CREDITS_OVERRIDE ?? await getDrupalOrgCredits({ uid: DRUPAL_ORG_UID });
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <div class="home-wrapper">
        <!-- Left column: photo + identity -->
        <aside class="home-sidebar">
          <Image
            src={ProfileImage}
            alt="Abhisek Mazumdar"
            class="profile-img"
            sizes="(max-width: 720px) 100px, 160px"
            loading="eager"
            fetchpriority="high"
          />
          <div class="identity">
            <p class="identity-name">Abhisek Mazumdar</p>
            <p class="identity-role">Drupal &amp; Mautic Engineer</p>
            <p class="identity-company">
              <a href="https://dropsolid.ai/" target="_blank" rel="noopener noreferrer">Dropsolid AI</a>
            </p>
            <a
              href="https://www.linkedin.com/in/abhisekmazumdar/"
              class="sidebar-linkedin"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn profile"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
            <div class="sidebar-credits-stat">
              <span class="sidebar-credits-num">{total}</span>
              <span class="sidebar-credits-lbl">Drupal.org credits</span>
            </div>
          </div>
        </aside>

        <!-- Right column: bio + credits -->
        <div class="home-body">
          <div class="bio-content">
            <About />
          </div>
          <div class="contact-cta">
            <a
              href="https://www.linkedin.com/in/abhisekmazumdar/"
              class="contact-btn"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              Connect on LinkedIn
            </a>
          </div>
          <DrupalCredits
            totalCount={total}
            projects={projects.map(({ label, count }) => ({ label, count }))}
            orgs={orgCredits.orgs}
            volunteerCount={orgCredits.volunteerCount}
            creditsUrl={DRUPAL_ORG_CREDITS_URL}
          />
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    flex: 1;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 4rem 1.25rem 4rem;
  }

  .home-wrapper {
    display: flex;
    align-items: flex-start;
    gap: 3.5rem;
    width: 100%;
    max-width: 900px;
  }

  /* ── Left column ─────────────────────────── */
  .home-sidebar {
    flex-shrink: 0;
    width: 160px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: sticky;
    top: 5.5rem;
    gap: 1rem;
  }

  .profile-img {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid rgba(var(--accent-rgb), 0.25);
    box-shadow: 0 0 0 6px rgba(var(--accent-rgb), 0.07);
  }

  .identity {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .identity-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: rgb(var(--black));
    margin: 0;
  }
  .identity-role {
    font-size: 0.75rem;
    color: rgb(var(--gray));
    margin: 0;
  }
  .identity-company {
    font-size: 0.75rem;
    margin: 0;
  }
  .identity-company a {
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
  }
  .identity-company a:hover {
    text-decoration: underline;
  }

  .sidebar-linkedin {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    margin-top: 0.5rem;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    opacity: 0.85;
    transition: opacity 0.15s;
  }
  .sidebar-linkedin:hover {
    opacity: 1;
  }

  .sidebar-credits-stat {
    margin-top: 0.65rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    padding-top: 0.65rem;
    border-top: 1px solid rgb(var(--gray-light));
    width: 100%;
  }
  .sidebar-credits-num {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
  }
  .sidebar-credits-lbl {
    font-size: 0.62rem;
    color: rgb(var(--gray));
    text-align: center;
    line-height: 1.3;
  }

  /* ── Right column ────────────────────────── */
  .home-body {
    flex: 1;
    min-width: 0;
    padding-top: 0.5rem;
  }

  .bio-content :global(p) {
    line-height: 1.8;
    margin: 0 0 1rem 0;
    text-align: left;
    color: rgb(var(--gray-dark));
    font-size: 1rem;
  }
  .bio-content :global(p:first-child) {
    font-size: 1.6rem;
    line-height: 1.35;
    font-weight: 700;
    color: rgb(var(--black));
    margin-bottom: 1.5rem;
  }
  .bio-content :global(a) {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid rgba(var(--accent-rgb), 0.3);
    transition: border-color 0.15s;
  }
  .bio-content :global(a:hover) {
    border-bottom-color: var(--accent);
  }

  /* ── LinkedIn CTA ────────────────────────── */
  .contact-cta {
    margin: 0.25rem 0 0;
  }

  .contact-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    padding: 0.45rem 1rem;
    border: 1.5px solid rgba(var(--accent-rgb), 0.45);
    border-radius: 999px;
    transition: background 0.15s, border-color 0.15s;
  }
  .contact-btn:hover {
    background: rgba(var(--accent-rgb), 0.08);
    border-color: var(--accent);
  }

  /* ── Mobile: stack ───────────────────────── */
  @media (max-width: 680px) {
    main {
      padding: 2.5rem 1rem;
    }

    .home-wrapper {
      flex-direction: column;
      gap: 2rem;
    }

    .home-sidebar {
      width: 100%;
      flex-direction: row;
      align-items: center;
      text-align: left;
      position: static;
      gap: 1.25rem;
    }

    .profile-img {
      width: 80px;
      height: 80px;
      flex-shrink: 0;
    }

    .identity {
      align-items: flex-start;
    }

    .sidebar-credits-stat {
      display: none;
    }

    .sidebar-linkedin {
      margin-top: 0.25rem;
    }

    .home-body {
      padding-top: 0;
    }

    .bio-content :global(p:first-child) {
      font-size: 1.3rem;
    }
  }
</style>
