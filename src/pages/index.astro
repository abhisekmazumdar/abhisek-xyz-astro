---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DrupalCredits from '../components/DrupalCredits.astro';
import {
  SITE_TITLE,
  SITE_DESCRIPTION,
  DRUPAL_ORG_UID,
  DRUPAL_CREDITS_OVERRIDE,
  DRUPAL_CREDITS_PROJECTS,
  DRUPAL_ORG_CREDITS_URL,
  DRUPAL_ORG_CREDITS_OVERRIDE,
} from '../consts';
import { getDrupalCredits } from '../lib/drupal-credits';
import { getDrupalOrgCredits } from '../lib/drupal-org-credits';
import ProfileImage from '../assets/abhisek.jpg';
import About from '../content/about.md';
import { Image } from 'astro:assets';

let { total, projects } = await getDrupalCredits({
  uid: DRUPAL_ORG_UID,
  projects: DRUPAL_CREDITS_PROJECTS,
});
const override = DRUPAL_CREDITS_OVERRIDE;
if (override) {
  if (override.total !== undefined) total = override.total;
  projects = projects.map((p) => ({
    ...p,
    count: override[p.machineName] ?? p.count,
  }));
}
const orgCredits = DRUPAL_ORG_CREDITS_OVERRIDE ?? await getDrupalOrgCredits({ uid: DRUPAL_ORG_UID });
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <div class="home-wrapper">
        <!-- Left column: photo + identity -->
        <aside class="home-sidebar">
          <Image
            src={ProfileImage}
            alt="Abhisek Mazumdar"
            class="profile-img"
            sizes="(max-width: 720px) 100px, 160px"
            loading="eager"
            fetchpriority="high"
          />
          <div class="identity">
            <p class="identity-name">Abhisek Mazumdar</p>
            <p class="identity-role">Drupal &amp; Mautic Engineer</p>
            <p class="identity-company">
              <a href="https://dropsolid.ai/" target="_blank" rel="noopener noreferrer">Dropsolid AI</a>
            </p>
            <div class="sidebar-social">
              <a href="https://drupal.org/u/abhisekmazumdar"        class="sidebar-social-btn" target="_blank" rel="noopener noreferrer" aria-label="Drupal" title="Drupal"><i class="fa-brands fa-drupal" aria-hidden="true"></i></a>
              <a href="https://github.com/abhisekmazumdar"          class="sidebar-social-btn" target="_blank" rel="noopener noreferrer" aria-label="GitHub" title="GitHub"><i class="fa-brands fa-github" aria-hidden="true"></i></a>
              <a href="https://www.instagram.com/abhisek.travel"    class="sidebar-social-btn" target="_blank" rel="noopener noreferrer" aria-label="Instagram" title="Instagram"><i class="fa-brands fa-instagram" aria-hidden="true"></i></a>
              <a href="https://www.reddit.com/user/abhisekmazumdar" class="sidebar-social-btn" target="_blank" rel="noopener noreferrer" aria-label="Reddit" title="Reddit"><i class="fa-brands fa-reddit-alien" aria-hidden="true"></i></a>
            </div>
            <a href="https://linkedin.com/in/abhisekmazumdar" class="sidebar-linkedin-btn" target="_blank" rel="noopener noreferrer">
              Connect on LinkedIn
            </a>
          </div>
        </aside>

        <!-- Right column: bio + credits -->
        <div class="home-body">
          <div class="bio-content">
            <About />
          </div>
          <DrupalCredits
            totalCount={total}
            projects={projects.map(({ label, count }) => ({ label, count }))}
            orgs={orgCredits.orgs}
            volunteerCount={orgCredits.volunteerCount}
            creditsUrl={DRUPAL_ORG_CREDITS_URL}
          />
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    flex: 1;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 4rem 1.25rem 4rem;
  }

  .home-wrapper {
    display: flex;
    align-items: flex-start;
    gap: 3.5rem;
    width: 100%;
    max-width: 900px;
  }

  /* ── Left column ─────────────────────────── */
  .home-sidebar {
    flex-shrink: 0;
    width: 160px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: sticky;
    top: 5.5rem;
    gap: 0.75rem;
  }

  .profile-img {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid rgba(var(--accent-rgb), 0.25);
    box-shadow: 0 0 0 6px rgba(var(--accent-rgb), 0.07);
  }

  .identity {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }

  .identity-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: rgb(var(--black));
    margin: 0;
  }
  .identity-role {
    font-size: 0.72rem;
    color: rgb(var(--gray));
    margin: 0;
  }
  .identity-company {
    font-size: 0.72rem;
    margin: 0;
  }
  .identity-company a {
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
  }
  .identity-company a:hover {
    text-decoration: underline;
  }

  .sidebar-social {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.1rem;
    margin-top: 0.3rem;
  }

  .sidebar-social-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.9rem;
    height: 1.9rem;
    border-radius: 7px;
    text-decoration: none;
    color: rgb(var(--gray));
    font-size: 0.9rem;
    transition: color 0.15s, background 0.15s;
  }
  .sidebar-social-btn:hover {
    color: var(--accent);
    background: rgba(var(--accent-rgb), 0.08);
  }

  .sidebar-linkedin-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    padding: 0.35rem 0.85rem;
    border: 1.5px solid rgba(var(--accent-rgb), 0.45);
    border-radius: 999px;
    transition: background 0.15s, border-color 0.15s;
    white-space: nowrap;
  }
  .sidebar-linkedin-btn:hover {
    background: rgba(var(--accent-rgb), 0.08);
    border-color: var(--accent);
  }

  /* ── Right column ────────────────────────── */
  .home-body {
    flex: 1;
    min-width: 0;
    padding-top: 0.5rem;
  }

  .bio-content :global(p) {
    line-height: 1.8;
    margin: 0 0 1rem 0;
    text-align: left;
    color: rgb(var(--gray-dark));
    font-size: 1rem;
  }
  .bio-content :global(p:first-child) {
    font-size: 1.6rem;
    line-height: 1.35;
    font-weight: 700;
    color: rgb(var(--black));
    margin-bottom: 1.5rem;
  }
  .bio-content :global(a) {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid rgba(var(--accent-rgb), 0.3);
    transition: border-color 0.15s;
  }
  .bio-content :global(a:hover) {
    border-bottom-color: var(--accent);
  }

  /* ── LinkedIn CTA ────────────────────────── */
  .contact-cta {
    margin: 0.25rem 0 0;
  }

  .contact-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    padding: 0.45rem 1rem;
    border: 1.5px solid rgba(var(--accent-rgb), 0.45);
    border-radius: 999px;
    transition: background 0.15s, border-color 0.15s;
  }
  .contact-btn:hover {
    background: rgba(var(--accent-rgb), 0.08);
    border-color: var(--accent);
  }

  /* ── Mobile: stack ───────────────────────── */
  @media (max-width: 680px) {
    main {
      padding: 2.5rem 1rem;
    }

    .home-wrapper {
      flex-direction: column;
      gap: 2rem;
    }

    .home-sidebar {
      width: 100%;
      flex-direction: row;
      align-items: center;
      text-align: left;
      position: static;
      gap: 1.25rem;
    }

    .profile-img {
      width: 80px;
      height: 80px;
      flex-shrink: 0;
    }

    .identity {
      align-items: flex-start;
    }

    .sidebar-social {
      margin-top: 0.15rem;
    }

    .home-body {
      padding-top: 0;
    }

    .bio-content :global(p:first-child) {
      font-size: 1.3rem;
    }
  }
</style>
