---
import DefaultLayout from '../../layouts/DefaultLayout.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const logs = (await getCollection('logs')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );
  const total = logs.length;
  return logs.map((log, index) => ({
    params: { slug: log.id },
    props: {
      log,
      entryId: String(total - index).padStart(3, '0'),
      prevLog: index > 0
        ? { id: logs[index - 1].id, title: logs[index - 1].data.title, pubDate: logs[index - 1].data.pubDate, entryId: String(total - (index - 1)).padStart(3, '0') }
        : null,
      nextLog: index < total - 1
        ? { id: logs[index + 1].id, title: logs[index + 1].data.title, pubDate: logs[index + 1].data.pubDate, entryId: String(total - (index + 1)).padStart(3, '0') }
        : null,
    },
  }));
}

interface Props {
  log: CollectionEntry<'logs'>;
  entryId: string;
  prevLog: { id: string; title: string; pubDate: Date; entryId: string } | null;
  nextLog: { id: string; title: string; pubDate: Date; entryId: string } | null;
}

const { log, entryId, prevLog, nextLog } = Astro.props;
const { Content } = await render(log);

function fmtDate(d: Date) {
  return d.toLocaleDateString('en-US', { month: 'short', day: '2-digit', year: 'numeric' }).toUpperCase();
}
function fmtDateShort(d: Date) {
  return d.toLocaleDateString('en-US', { month: 'short', day: '2-digit' }).toUpperCase();
}
---

<DefaultLayout title={log.data.title} description={log.data.description} image={log.data.coverImage}>
  <article class="log-post">

    <!-- Back breadcrumb -->
    <a href="/logs/" class="breadcrumb">
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none"
        stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
        aria-hidden="true" class="breadcrumb-arrow">
        <path d="m15 18-6-6 6-6"/>
      </svg>
      <span class="breadcrumb-path">logs/</span>
    </a>

    <!-- Log file header block -->
    <header class="log-header">
      <div class="header-rule"></div>

      <div class="header-meta">
        <span class="header-id">#{entryId}</span>
        <span class="header-sep" aria-hidden="true">·</span>
        <span class="header-date">{fmtDate(log.data.pubDate)}</span>
        {log.data.updatedDate && (
          <>
            <span class="header-sep" aria-hidden="true">·</span>
            <span class="header-updated">UPDATED {fmtDateShort(log.data.updatedDate)}</span>
          </>
        )}
      </div>

      <div class="header-rule"></div>

      <h1 class="post-title">{log.data.title}</h1>

      {log.data.description && (
        <p class="post-desc">{log.data.description}</p>
      )}
    </header>

    <!-- Hero image -->
    {log.data.coverImage && (
      <div class="hero-wrap">
        <Image
          src={log.data.coverImage}
          alt={log.data.title}
          width={1200}
          height={630}
          class="hero-img"
        />
      </div>
    )}

    <!-- Body content -->
    <div class="log-content">
      <Content />
    </div>

    <!-- Footer navigation -->
    <footer class="post-footer">
      <div class="footer-rule"></div>
      <nav class="log-nav" aria-label="Log entry navigation">
        <div class="nav-side nav-prev">
          {prevLog ? (
            <a href={`/logs/${prevLog.id}/`} class="nav-link nav-link--prev">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                aria-hidden="true">
                <path d="m15 18-6-6 6-6"/>
              </svg>
              <span class="nav-entry">
                <span class="nav-id">#{prevLog.entryId} · {fmtDateShort(prevLog.pubDate)}</span>
                <span class="nav-title">{prevLog.title}</span>
              </span>
            </a>
          ) : (
            <a href="/logs/" class="nav-link nav-link--prev">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                aria-hidden="true">
                <path d="m15 18-6-6 6-6"/>
              </svg>
              <span class="nav-entry">
                <span class="nav-id">logs/</span>
                <span class="nav-title">Back to all entries</span>
              </span>
            </a>
          )}
        </div>

        <div class="nav-side nav-next">
          {nextLog && (
            <a href={`/logs/${nextLog.id}/`} class="nav-link nav-link--next">
              <span class="nav-entry">
                <span class="nav-id">{fmtDateShort(nextLog.pubDate)} · #{nextLog.entryId}</span>
                <span class="nav-title">{nextLog.title}</span>
              </span>
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                aria-hidden="true">
                <path d="m9 18 6-6-6-6"/>
              </svg>
            </a>
          )}
        </div>
      </nav>
    </footer>

  </article>
</DefaultLayout>

<style>
  /* ── Breadcrumb ──────────────────────────── */
  .breadcrumb {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.78rem;
    font-weight: 600;
    color: rgb(var(--gray));
    text-decoration: none;
    margin-bottom: 1.75rem;
    transition: color 0.15s;
  }
  .breadcrumb:hover {
    color: var(--accent);
  }
  .breadcrumb-arrow {
    transition: transform 0.15s;
  }
  .breadcrumb:hover .breadcrumb-arrow {
    transform: translateX(-2px);
  }
  .breadcrumb-path {
    letter-spacing: 0.04em;
  }

  /* ── Log header block ────────────────────── */
  .log-header {
    margin-bottom: 2.5rem;
  }
  .header-rule {
    height: 1px;
    background: rgb(var(--gray-light));
    margin: 0.75rem 0;
  }
  .header-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.75rem;
    flex-wrap: wrap;
  }
  .header-id {
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.04em;
  }
  .header-sep {
    color: rgb(var(--gray-light));
  }
  .header-date {
    color: rgb(var(--gray));
    letter-spacing: 0.06em;
  }
  .header-updated {
    color: rgb(var(--gray));
    font-style: italic;
    letter-spacing: 0.04em;
  }

  .post-title {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.25;
    color: rgb(var(--black));
    margin: 1.25rem 0 0.6rem;
  }
  .post-desc {
    font-size: 1rem;
    color: rgb(var(--gray));
    line-height: 1.65;
    margin: 0;
  }

  /* ── Hero image ──────────────────────────── */
  .hero-wrap {
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 2.5rem;
    aspect-ratio: 16 / 9;
  }
  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    margin: 0;
    display: block;
  }

  /* ── Body content ────────────────────────── */
  .log-content {
    line-height: 1.8;
    font-size: 1rem;
  }
  .log-content :global(p)           { margin-bottom: 1.5em; }
  .log-content :global(h2),
  .log-content :global(h3),
  .log-content :global(h4)          { margin-top: 2em; margin-bottom: 0.75em; }
  .log-content :global(a)           { text-decoration: underline; text-underline-offset: 3px; }
  .log-content :global(img)         { border-radius: 10px; margin: 2em auto; display: block; }
  .log-content :global(ul),
  .log-content :global(ol)          { padding-left: 1.5em; margin-bottom: 1.5em; }
  .log-content :global(li)          { margin-bottom: 0.5em; }

  /* ── Footer navigation ───────────────────── */
  .post-footer {
    margin-top: 3.5rem;
  }
  .footer-rule {
    height: 1px;
    background: rgb(var(--gray-light));
    margin-bottom: 1.25rem;
  }
  .log-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }
  .nav-side {
    flex: 1;
    min-width: 0;
  }
  .nav-next {
    display: flex;
    justify-content: flex-end;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: inherit;
    max-width: 100%;
    padding: 0.5rem 0.6rem;
    border-radius: 8px;
    transition: background 0.15s, color 0.15s;
  }
  .nav-link:hover {
    background: rgba(var(--accent-rgb), 0.05);
  }
  .nav-link--next {
    text-align: right;
  }

  .nav-entry {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }
  .nav-link--next .nav-entry {
    align-items: flex-end;
  }

  .nav-id {
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }
  .nav-title {
    font-size: 0.82rem;
    font-weight: 600;
    color: rgb(var(--gray-dark));
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: color 0.15s;
  }
  .nav-link:hover .nav-title {
    color: var(--accent);
  }
  .nav-link svg {
    flex-shrink: 0;
    color: rgb(var(--gray));
    transition: transform 0.15s, color 0.15s;
  }
  .nav-link--prev:hover svg {
    transform: translateX(-2px);
    color: var(--accent);
  }
  .nav-link--next:hover svg {
    transform: translateX(2px);
    color: var(--accent);
  }

  /* ── Mobile ──────────────────────────────── */
  @media (max-width: 560px) {
    .post-title  { font-size: 1.6rem; }
    .log-nav     { flex-direction: column; gap: 0.5rem; }
    .nav-next    { justify-content: flex-start; }
    .nav-link--next .nav-entry { align-items: flex-start; }
    .nav-title   { white-space: normal; }
  }
</style>
