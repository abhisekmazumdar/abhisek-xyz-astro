---
import DefaultLayout from '../../layouts/DefaultLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const logs = await getCollection('logs');
  return logs.map((log) => ({
    params: { slug: log.id },
    props: log,
  }));
}

type Props = CollectionEntry<'logs'>;

const log = Astro.props;
const { Content } = await render(log);
---

<DefaultLayout title={log.data.title} description={log.data.description} image={log.data.coverImage}>
  <article class="log-post">
    <!-- Back link -->
    <a href="/logs/" class="back-link">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
        stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
        aria-hidden="true" class="back-arrow">
        <path d="m15 18-6-6 6-6"/>
      </svg>
      All logs
    </a>

    <header class="post-header">
      <div class="meta-row">
        <span class="date-badge">
          <FormattedDate date={log.data.pubDate} />
        </span>
        {log.data.updatedDate && (
          <span class="updated-note">
            Updated <FormattedDate date={log.data.updatedDate} />
          </span>
        )}
      </div>

      <h1 class="post-title">{log.data.title}</h1>

      {log.data.description && (
        <p class="post-desc">{log.data.description}</p>
      )}
    </header>

    {log.data.coverImage && (
      <div class="hero-wrap">
        <Image
          src={log.data.coverImage}
          alt={log.data.title}
          width={1200}
          height={630}
          class="hero-img"
        />
      </div>
    )}

    <div class="log-content">
      <Content />
    </div>

    <footer class="post-footer">
      <a href="/logs/" class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
          aria-hidden="true" class="back-arrow">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        All logs
      </a>
    </footer>
  </article>
</DefaultLayout>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: rgb(var(--gray));
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color 0.15s;
  }
  .back-link:hover {
    color: var(--accent);
  }
  .back-arrow {
    transition: transform 0.15s;
  }
  .back-link:hover .back-arrow {
    transform: translateX(-2px);
  }

  .post-header {
    margin-bottom: 2rem;
  }
  .meta-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .date-badge {
    display: inline-flex;
    align-items: center;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--accent);
    background: rgba(var(--accent-rgb), 0.1);
    border-radius: 999px;
    padding: 0.2rem 0.75rem;
  }
  .updated-note {
    font-size: 0.78rem;
    font-style: italic;
    color: rgb(var(--gray));
  }

  .post-title {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.25;
    color: rgb(var(--black));
    margin: 0 0 0.75rem;
  }
  .post-desc {
    font-size: 1.05rem;
    color: rgb(var(--gray));
    line-height: 1.6;
    margin: 0;
  }

  .hero-wrap {
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 2.5rem;
    aspect-ratio: 16 / 9;
  }
  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    margin: 0;
    display: block;
  }

  .log-content {
    line-height: 1.8;
    font-size: 1rem;
  }
  .log-content :global(p) { margin-bottom: 1.5em; }
  .log-content :global(h2),
  .log-content :global(h3),
  .log-content :global(h4) {
    margin-top: 2em;
    margin-bottom: 0.75em;
  }
  .log-content :global(a) {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .log-content :global(img) {
    border-radius: 10px;
    margin: 2em auto;
    display: block;
  }
  .log-content :global(ul),
  .log-content :global(ol) {
    padding-left: 1.5em;
    margin-bottom: 1.5em;
  }
  .log-content :global(li) { margin-bottom: 0.5em; }

  .post-footer {
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgb(var(--gray-light));
  }
</style>
